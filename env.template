# =========================
# Intermapper (scraping)
# =========================
INTERMAPPER_URL="http://tu-intermapper.com"
INTERMAPPER_USER="tu_usuario"
INTERMAPPER_PASS="tu_clave"
CONCURRENT_WORKERS=3
# Reintentos por site si falla la captura o el device list (estabiliza ip_map.json).
SITE_PROCESS_RETRIES=2
DEVICE_LIST_TIMEOUT_MS=90000

# =========================
# n8n (webhook que recibe los PNG)
# =========================
N8N_WEBHOOK_URL="http://tu-n8n.com/webhook/procesar-mapa"
# Segundos entre cada envío de imagen a n8n. 60 = 1 imagen por minuto.
N8N_SEND_INTERVAL_SECONDS=60

# =========================
# Base de datos MySQL
# =========================
# Si corres Docker y tu MySQL está en el host: usa "host.docker.internal".
DB_HOST="localhost"
DB_USER="tu_usuario_mysql"
DB_PASS="tu_clave_mysql"
DB_NAME="intermapper_db"

# =========================
# Servidor MCP (recibe las llamadas de n8n)
# =========================
MCP_BEARER_TOKEN="tu_token_secreto_super_seguro_aqui"
MCP_HOST="0.0.0.0"
MCP_PORT=8000
# Hosts permitidos por la protección DNS-rebinding del SDK, separados por coma.
# Déjalo vacío para deshabilitarla (válido si confías en el Bearer token).
# Ejemplo: MCP_ALLOWED_HOSTS="mi-dominio.com,123.45.67.89:8000"
MCP_ALLOWED_HOSTS=""
# Transportes MCP:
#   n8n Endpoint (HTTP Streamable): https://<host>/mcp  ← usar este en n8n
#   n8n Endpoint (SSE legacy):      https://<host>/sse
MCP_ENABLE_STREAMABLE=true
# SSE legacy: dejar en false si n8n usa /mcp (evita conexiones colgadas extra).
MCP_ENABLE_SSE=false
# true = sin sesiones persistentes (recomendado para n8n: ~1 sesión por llamada al tool).
MCP_STATELESS_HTTP=true
# Solo si MCP_STATELESS_HTTP=false: segundos sin tráfico antes de cerrar la sesión SSE.
MCP_SESSION_IDLE_TIMEOUT=120
# Máximo de sync_intermapper_data en paralelo (evita saturar MySQL/event loop)
MCP_MAX_CONCURRENT_SYNCS=6
# Límite global de conexiones HTTP de uvicorn (stateless evita agotarlo con ~50+ torres).
MCP_LIMIT_CONCURRENCY=200

# =========================
# Orquestación del entrypoint unificado (main.py)
# =========================
# Habilita/deshabilita cada componente del proceso.
RUN_MCP=true
RUN_PIPELINE=true
# Cómo se ejecuta el pipeline cuando RUN_PIPELINE=true:
#   once → corre una sola vez, luego el MCP queda escuchando solo.
#   loop → repite cada PIPELINE_INTERVAL_SECONDS para siempre.
PIPELINE_MODE=once
PIPELINE_INTERVAL_SECONDS=3600
# Segundos a esperar antes de la primera corrida (deja al MCP estar listo).
PIPELINE_INITIAL_DELAY_SECONDS=5
